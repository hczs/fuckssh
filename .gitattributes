# 源码与配置统一 LF，避免 Windows 检出 CRLF 导致 CI gofmt 失败。
* text=auto

*.go          text eol=lf
go.mod        text eol=lf
go.sum        text eol=lf
Makefile      text eol=lf
*.mk          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.sh          text eol=lf
.githooks/*   text eol=lf
*.md          text eol=lf
*.html        text eol=lf
*.json        text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
.golangci.yml text eol=lf

# 二进制不参与换行转换
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.woff        binary
*.woff2       binary
